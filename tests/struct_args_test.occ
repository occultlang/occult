include "../std/stdio.occ"

struct point {
    i64 x;
    i64 y;
}

fn print_point(point p) {
    std::print_integer(p.x);
    std::print_string(" ");
    std::print_integer(p.y);
    std::print_string("\n");
}

fn main() {
    point p;
    p.x = 42;
    p.y = 99;

    print_point(p);

    return 0;
}
