include "../lib/printf.occ"

enum Direction {
    North,
    South,
    East,
    West
}

struct Player {
    i64 x;
    i64 y;
    Direction facing;
}

fn main() i64 {
    Player p;
    p.x = 10;
    p.y = 20;
    p.facing = Direction::East;

    printf("x=%i y=%i facing=%i\n", p.x, p.y, p.facing);
    return 0;
}
