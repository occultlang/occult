include "../std/stdio.occ"

fn main() i64 {
    // Test 1: fallthrough from case 1 to case 2 block
    i64 x = 1;
    switch (x) {
        case 1:
        case 2: {
            std::printf("1 or 2\n");
        }
        case 3: {
            std::printf("3\n");
        }
        default: {
            std::printf("other\n");
        }
    }

    // Test 2: fallthrough from case 3 to case 4 to case 5
    i64 y = 3;
    switch (y) {
        case 1: {
            std::printf("one\n");
        }
        case 3:
        case 4:
        case 5: {
            std::printf("3, 4, or 5\n");
        }
        default: {
            std::printf("default\n");
        }
    }

    // Test 3: no match, still goes to default
    i64 z = 99;
    switch (z) {
        case 1:
        case 2: {
            std::printf("1 or 2\n");
        }
        default: {
            std::printf("no match default\n");
        }
    }

    std::printf("done\n");
    return 0;
}
