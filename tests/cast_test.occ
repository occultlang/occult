include "../std/stdio.occ"

fn main() {
    i64 x = 42;
    f32 as_float = f32(x);
    std::__printf_float(__bitcast_i64(f64(as_float)), 1);
    std::print_string("\n");

    f32 pi = 3.14;
    i64 truncated = i64(pi);
    std::print_integer(truncated);
    std::print_string("\n");

    i64 big = 300;
    i8 narrow = i8(big);
    std::print_integer(narrow);
    std::print_string("\n");

    f64 d = f64(pi);
    f32 back = f32(d);
    std::__printf_float(__bitcast_i64(f64(back)), 2);
    std::print_string("\n");

    return 0;
}