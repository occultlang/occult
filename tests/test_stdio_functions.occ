// Test case for stdio with functions
include "../std/stdio.occ"

fn greet(string name) i64 {
    std::print_string("Hello, ");
    std::print_string(name);
    std::print_string("!");
    std::print_newline();
    return 0;
}

fn print_sum(i64 a, i64 b) i64 {
    i64 sum = a + b;
    std::print_string("Sum: ");
    std::print_integer(sum);
    std::print_newline();
    return sum;
}

fn main() i64 {
    greet("Occult");
    
    print_sum(10, 20);
    print_sum(100, 200);
    
    return 0;
}
