// Test case for stdio with loops
include "../std/stdio.occ"

fn main() i64 {
    std::print_string("Counting from 0 to 5:");
    std::print_newline();
    
    for i64 i = 0 when i <= 5 do i = i + 1 {
        std::print_string("  Count: ");
        std::print_integer(i);
        std::print_newline();
    }
    
    std::print_string("Done!");
    std::print_newline();
    
    return 0;
}
