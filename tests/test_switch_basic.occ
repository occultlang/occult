include "../std/stdio.occ"

fn main() i64 {
    i64 x = 2;

    switch (x) {
        case 1: {
            std::printf("one\n");
        }
        case 2: {
            std::printf("two\n");
        }
        case 3: {
            std::printf("three\n");
        }
        default: {
            std::printf("other\n");
        }
    }

    return 0;
}
