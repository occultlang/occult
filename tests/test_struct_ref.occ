include "../std/stdio.occ"

struct Point {
    i64 x;
    i64 y;
}

fn set_point(Point@ p, i64 a, i64 b) {
    $p.x = a;
    $p.y = b;
}

fn main() {
    Point p;
    p.x = 1;
    p.y = 2;
    
    std::print_string("Before: p = (");
    std::print_integer(p.x);
    std::print_string(", ");
    std::print_integer(p.y);
    std::print_string(")\n");
    
    set_point(p, 10, 20);
    
    std::print_string("After set_point: p = (");
    std::print_integer(p.x);
    std::print_string(", ");
    std::print_integer(p.y);
    std::print_string(")\n");
    
    return 0;
}
