include "../std/stdio.occ"

fn main() {
    std::printf("Integer: %d\n", 42);
    std::printf("String: %s\n", "hello");
    std::printf("Float default: %f\n", 100.0);
    std::printf("Float .2: %.2f\n", 100.42);
    std::printf("Float .4: %.4f\n", 100.1234);
    std::printf("Negative: %.2f\n", -42.30);
    std::printf("Mixed: %s scored %.1f out of %d\n", "Alice", 95.1, 100);
}
