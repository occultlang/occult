include "../std/stdio.occ"

enum State {
    Idle,
    Running,
    Stopped
}

fn main() i64 {
    State s = State::Running;
    std::printf("State = %i\n", s);

    if (s == State::Running) {
        std::printf("Is running!\n");
    }

    s = State::Stopped;
    std::printf("New state = %i\n", s);
    return 0;
}
