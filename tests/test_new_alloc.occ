include "../std/stdio.occ"

fn main() i64 {
    std::print_string("Testing new mmap-based alloc/del...");
    std::print_newline();
    
    // Test 1: Simple allocation and deallocation
    std::print_string("Test 1: Simple alloc/del");
    std::print_newline();
    i64 p = std::malloc(100);
    $p = 42;
    i64 val = $p;
    std::print_string("  Stored: 42, Retrieved: ");
    std::print_integer(val);
    std::print_newline();
    std::free(p);
    std::print_string("  PASS");
    std::print_newline();
    
    // Test 2: Multiple allocations
    std::print_string("Test 2: Multiple allocations");
    std::print_newline();
    i64 ptr1 = std::malloc(10);
    i64 ptr2 = std::malloc(20);
    i64 ptr3 = std::malloc(30);
    $ptr1 = 100;
    $ptr2 = 200;
    $ptr3 = 300;
    std::print_string("  ptr1: ");
    std::print_integer($ptr1);
    std::print_string(", ptr2: ");
    std::print_integer($ptr2);
    std::print_string(", ptr3: ");
    std::print_integer($ptr3);
    std::print_newline();
    std::free(ptr1);
    std::free(ptr2);
    std::free(ptr3);
    std::print_string("  PASS");
    std::print_newline();
    
    // Test 3: Array usage
    std::print_string("Test 3: Array with dynamic allocation");
    std::print_newline();
    array[5] i64 arr;
    arr[0] = std::malloc(1);
    arr[1] = std::malloc(1);
    arr[2] = std::malloc(1);
    // Workaround: Parser doesn't support $arr[idx] syntax, use temp variables
    i64 p0 = arr[0];
    i64 p1 = arr[1];
    i64 p2 = arr[2];
    $p0 = 65;  // 'A'
    $p1 = 66;  // 'B'
    $p2 = 67;  // 'C'
    std::print_string("  Values: ");
    std::print_integer($p0);
    std::print_string(" ");
    std::print_integer($p1);
    std::print_string(" ");
    std::print_integer($p2);
    std::print_newline();
    std::free(arr[0]);
    std::free(arr[1]);
    std::free(arr[2]);
    std::print_string("  PASS");
    std::print_newline();
    
    std::print_string("All tests passed!");
    std::print_newline();
    
    return 0;
}
