include "../std/stdio.occ"

fn main() i64 {
    std::print_string("=== Comprehensive Test Suite ===");
    std::print_newline();
    
    // Test 1: Variable declarations (both initialized and uninitialized)
    std::print_string("Test 1: Variable declarations");
    std::print_newline();
    i64 uninit_var;
    i64 init_var = 42;
    uninit_var = 100;
    std::print_integer(uninit_var);
    std::print_newline();
    std::print_integer(init_var);
    std::print_newline();
    
    // Test 2: Arrays
    std::print_string("Test 2: Arrays");
    std::print_newline();
    array[3] i64 arr;
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    std::print_integer(arr[0]);
    std::print_newline();
    std::print_integer(arr[1]);
    std::print_newline();
    std::print_integer(arr[2]);
    std::print_newline();
    
    // Test 3: Dynamic array indexing
    std::print_string("Test 3: Dynamic array indexing");
    std::print_newline();
    i64 idx = 1;
    std::print_integer(arr[idx]);
    std::print_newline();
    
    // Test 4: Memory allocation
    std::print_string("Test 4: Memory allocation");
    std::print_newline();
    i64 addr = std::malloc(8);
    $addr = 999;
    std::print_integer($addr);
    std::print_newline();
    std::free(addr);
    
    // Test 5: Loops
    std::print_string("Test 5: Loops");
    std::print_newline();
    i64 i = 0;
    loop {
        if i >= 3 {
            break;
        }
        std::print_integer(arr[i]);
        std::print_newline();
        i = i + 1;
    }
    
    std::print_string("All tests passed!");
    std::print_newline();
    
    return 0;
}
