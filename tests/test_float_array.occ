// Test float arithmetic and cast to i64 (BUG H7 related)
// Expected: return 0 (int_sum should be 7)
include "../std/stdio.occ"

fn main() i64 {
    f32 a = 1.5;
    f32 b = 2.5;
    f32 c = 3.5;
    f32 sum = a + b + c;
    // sum should be 7.5, int part = 7
    i64 int_sum = i64(sum);
    return int_sum - 7;
}
