include "../std/stdio.occ"

fn main() {
    std::printf("Hello %s! You are %d years old.\n", "World", 25);
    std::printf("Hex: %x\n", 255);
    std::printf("Char: %c\n", 65);
    std::printf("Percent: %%\n");
    std::printf("Multiple: %d + %d = %d\n", 10, 20, 30);
    std::printf("%f\n", 8.1238);
}
