include "../std/stdio.occ"

enum Color {
    Red,
    Green,
    Blue
}

fn main() i64 {
    i64 c = Color::Green;

    switch (c) {
        case 0: {
            std::printf("Red\n");
        }
        case 1: {
            std::printf("Green\n");
        }
        case 2: {
            std::printf("Blue\n");
        }
        default: {
            std::printf("Unknown\n");
        }
    }

    return 0;
}
