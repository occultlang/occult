include "../std/stdio.occ"

generic<T>
struct gnode {
    T val;
    gnode* next;
}

generic<T>
fn alloc_gnode(T val) gnode<T>* {
    gnode<T>* n = std::malloc(16);
    n.val = val;
    n.next = 0;
    return n;
}

generic<T>
fn get_val(gnode<T>* node) T {
    return node.val;
}

fn main() i64 {
    gnode<i64>* head = alloc_gnode<i64>(10);
    std::print_integer(get_val<i64>(head));
    std::print_string("\n");
    std::free(head);
    return 0;
}
