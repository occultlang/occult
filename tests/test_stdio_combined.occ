// Test case for combined stdio functions
include "../std/stdio.occ"

fn main() i64 {
    // Test combining all functions
    std::print_string("Testing stdio library:");
    std::print_newline();
    
    std::print_string("  Integer test: ");
    std::print_integer(12345);
    std::print_newline();
    
    std::print_string("  Negative test: ");
    std::print_integer(0 - 678);
    std::print_newline();
    
    std::print_string("  Zero test: ");
    std::print_integer(0);
    std::print_newline();
    
    std::print_string("All tests completed!");
    std::print_newline();
    
    return 0;
}
