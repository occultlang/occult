include "../std/stdio.occ"

// Incremental Test - Step by step test of all features
// This test verifies core language features work correctly

fn main() i64 {
    std::print_string("=== Incremental Test Suite ===\n");
    
    // Test 1: Basic variables
    std::print_string("\n[TEST 1] Variables and arithmetic\n");
    i64 x = 10;
    i64 y = 20;
    i64 z = x + y;
    std::print_string("x + y = ");
    std::print_integer(z);
    std::print_newline();
    
    // Test 2: Arrays
    std::print_string("\n[TEST 2] Array declaration and access\n");
    array[5] i64 arr;
    arr[0] = 100;
    arr[1] = 200;
    arr[2] = 300;
    std::print_string("arr[1] = ");
    std::print_integer(arr[1]);
    std::print_newline();
    
    // Test 3: Loops
    std::print_string("\n[TEST 3] Loop with counter\n");
    i64 count = 0;
    i64 i = 0;
    loop {
        if i >= 5 {
            break;
        }
        count = count + i;
        i = i + 1;
    }
    std::print_string("Sum 0-4 = ");
    std::print_integer(count);
    std::print_newline();
    
    // Test 4: Dynamic array indexing
    std::print_string("\n[TEST 4] Dynamic array indexing\n");
    array[10] i64 nums;
    i64 idx = 0;
    loop {
        if idx >= 5 {
            break;
        }
        nums[idx] = idx * 10;
        idx = idx + 1;
    }
    std::print_string("nums[3] = ");
    std::print_integer(nums[3]);
    std::print_newline();
    
    // Test 5: Memory allocation and dereferencing
    std::print_string("\n[TEST 5] Memory allocation\n");
    i64 p = std::malloc(8);
    $p = 999;
    i64 value = $p;
    std::print_string("Stored value = ");
    std::print_integer(value);
    std::print_newline();
    std::free(p);
    
    // Test 6: Pointer arithmetic
    std::print_string("\n[TEST 6] Pointer arithmetic\n");
    i64 block = std::malloc(40);
    $(block + 0) = 111;
    $(block + 8) = 222;
    $(block + 16) = 333;
    std::print_string("block[2] = ");
    std::print_integer($(block + 16));
    std::print_newline();
    std::free(block);
    
    // Test 7: Array with pointers
    std::print_string("\n[TEST 7] Array storing pointers\n");
    array[3] i64 addresses;
    i64 node1 = std::malloc(16);
    $node1 = 1;
    $(node1 + 8) = 0;
    
    i64 node2 = std::malloc(16);
    $node2 = 2;
    $(node2 + 8) = 0;
    
    addresses[0] = node1;
    addresses[1] = node2;
    
    i64 retrieved = addresses[0];
    std::print_string("First node data = ");
    std::print_integer($retrieved);
    std::print_newline();
    
    std::free(node1);
    std::free(node2);
    
    std::print_string("\n=== All Tests Complete ===\n");
    return 0;
}
