include "../std/stdio.occ"
include "../std/vec.occ"

fn main() i64 {
    vec::Vec<i64>* v = vec::new<i64>();

    for i64 i = 0 when i < 100 do i += 10 {
        vec::push<i64>(v, i);
    }

    std::printf("Vec elements: ");
    i64 i = 0;
    while i < v.length {
        std::printf("%i ", vec::get<i64>(v, i));
        i += 1;
    }
    std::printf("\n");

    std::printf("Length: %i\n", v.length);
    std::printf("Capacity: %i\n", v.capacity);

    return 0;
}
