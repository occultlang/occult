// Test case for print_integer function
include "../std/stdio.occ"

fn main() i64 {
    // Test positive numbers
    std::print_string("Positive: ");
    std::print_integer(42);
    std::print_newline();
    
    // Test zero
    std::print_string("Zero: ");
    std::print_integer(0);
    std::print_newline();
    
    // Test negative numbers
    std::print_string("Negative: ");
    std::print_integer(0 - 123);
    std::print_newline();
    
    // Test large numbers
    std::print_string("Large: ");
    std::print_integer(999999);
    std::print_newline();
    
    return 0;
}
