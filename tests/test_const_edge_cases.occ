include "../std/stdio.occ"

fn main() i64 {
    // Edge case: const without initialization should fail
    // This test verifies const enforcement works
    const i64 a = 1;
    const i64 b = 2;
    i64 c = a + b;
    std::printf("a + b = ");
    std::printf("%d\n", c);

    // Edge case: const with different types
    const i32 small = 42;
    std::printf("small = ");
    std::printf("%d\n", small);

    return 0;
}
