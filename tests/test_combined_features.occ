include "../std/stdio.occ"

// Global constants
const i64 MAX_ITEMS = 5;

// Global enum
enum Category {
    TypeA,
    TypeB,
    TypeC,
    TypeD = 10,
    TypeE
}

// Global variable
i64 total_count = 0;

fn categorize(i64 cat) i64 {
    switch (cat) {
        case 0:
        case 1:
        case 2: {
            std::print_string("basic type (A/B/C)\n");
        }
        case 10:
        case 11: {
            std::print_string("advanced type (D/E)\n");
        }
        default: {
            std::print_string("unknown type\n");
        }
    }
    return 0;
}

fn process_item(i64 id) i64 {
    std::print_string("processing item ");
    std::print_integer(id);
    std::print_string(", total so far: ");
    std::print_integer(total_count);
    std::print_string("\n");

    // Use global const in comparison
    if (id < MAX_ITEMS) {
        std::print_string("  within limit\n");
    }
    return 0;
}

fn main() i64 {
    // Use enum values in switch with fallthrough
    categorize(Category::TypeA);
    categorize(Category::TypeC);
    categorize(Category::TypeD);
    categorize(Category::TypeE);
    categorize(99);

    // Use const global in loop
    i64 i = 0;
    while (i < MAX_ITEMS) {
        process_item(i);
        i = i + 1;
    }

    // Enum in expressions
    i64 cat_sum = Category::TypeA + Category::TypeB + Category::TypeC;
    std::print_string("category sum: ");
    std::print_integer(cat_sum);
    std::print_string("\n");

    // Switch on enum value
    i64 my_type = Category::TypeD;
    switch (my_type) {
        case 10: {
            std::print_string("TypeD confirmed\n");
        }
        default: {
            std::print_string("not TypeD\n");
        }
    }

    std::print_string("combined test done\n");
    return 0;
}
