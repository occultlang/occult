include "../std/stdio.occ"

struct Point {
    i64 x;
    i64 y;
}

fn get_x(Point@ p) i64 {
    return $p.x;
}

fn get_y(Point@ p) i64 {
    return $p.y;
}

fn main() {
    Point p;
    p.x = 42;
    p.y = 99;
    
    i64 x = get_x(p);
    i64 y = get_y(p);
    
    std::print_string("x = ");
    std::print_integer(x);
    std::print_string(" (expected 42)\n");
    
    std::print_string("y = ");
    std::print_integer(y);
    std::print_string(" (expected 99)\n");
    
    return 0;
}
