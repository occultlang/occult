include "../std/memory.occ"
include "../std/stdio.occ"

fn alloc(i64 len) i64 {
    return std::malloc(len);
}

fn del(i64 ptr) {
    std::free(ptr);
}

fn malloc(i64 size) shellcode i64 { 0x55 0x48 0x89 0xE5 0x48 0x89 0xFE 0xB8 0x0C 0x00 0x00 0x00 0x48 0x31 0xFF 0x0F 0x05 0x48 0x89 0xC7 0x48 0x01 0xF7 0xB8 0x0C 0x00 0x00 0x00 0x0F 0x05 0x48 0x89 0xEC 0x5D 0xC3 }

// Helper for write syscall
fn syscall_write(i64 fd, i64 buf, i64 count) shellcode i64 {
    0x55                    // push rbp
    0x48 0x89 0xE5          // mov rbp, rsp
    0xB8 0x01 0x00 0x00 0x00 // mov eax, 1 (sys_write)
    0x0F 0x05               // syscall
    0x48 0x89 0xEC          // mov rsp, rbp
    0x5D                    // pop rbp
    0xC3                    // ret
}

// print_string - prints a null-terminated string
fn print_string(i64 str) {
    i64 len = 0;
    i64 temp = str;
    loop {
        i64 char_val = $temp;
        if char_val == 0 {
            break;
        }
        len = len + 1;
        temp = temp + 1;
    }
    syscall_write(1, str, len);
}

// Helper to allocate a single character  
fn alloc_char(i64 c) i64 {
    i64 mem = std::malloc(1);
    $mem = c;
    return mem;
}

// print_integer - prints a signed 64-bit integer
fn print_integer(i64 num) {
    if num < 0 {
        syscall_write(1, alloc_char(45), 1);
        num = 0 - num;
    }
    
    if num == 0 {
        syscall_write(1, alloc_char(48), 1);
        return 0;
    }
    
    array[20] i64 digits;
    i64 digit_count = 0;
    
    loop {
        if num == 0 {
            break;
        }
        i64 digit = num % 10;
        digits[digit_count] = digit + 48;
        digit_count = digit_count + 1;
        num = num / 10;
    }
    
    loop {
        if digit_count == 0 {
            break;
        }
        digit_count = digit_count - 1;
        i64 char_val = digits[digit_count];
        syscall_write(1, alloc_char(char_val), 1);
    }
    
    return 0;
}

fn main() {
    std::print_string("=== Comprehensive Language Feature Test ===\n\n");
    
    // Test 1: Basic variables
    std::print_string("Test 1: Basic Variables\n");
    i64 a = 10;
    i64 b = 20;
    i64 sum = a + b;
    std::print_string("  10 + 20 = ");
    std::print_integer(sum);
    std::print_string("\n");
    
    // Test 2: Arithmetic operations
    std::print_string("\nTest 2: Arithmetic Operations\n");
    i64 x = 100;
    i64 y = 25;
    std::print_string("  100 - 25 = ");
    std::print_integer(x - y);
    std::print_string("\n");
    std::print_string("  100 * 2 = ");
    std::print_integer(x * 2);
    std::print_string("\n");
    std::print_string("  100 / 25 = ");
    std::print_integer(x / y);
    std::print_string("\n");
    
    // Test 3: Simple loop
    std::print_string("\nTest 3: Simple Loop\n");
    i64 counter = 0;
    i64 loop_sum = 0;
    loop {
        if counter >= 5 {
            break;
        }
        loop_sum = loop_sum + counter;
        counter = counter + 1;
    }
    std::print_string("  Sum of 0-4: ");
    std::print_integer(loop_sum);
    std::print_string("\n");
    
    // Test 4: Array declaration and initialization
    std::print_string("\nTest 4: Array Declaration\n");
    array[5] i64 arr;
    arr[0] = 100;
    arr[1] = 200;
    arr[2] = 300;
    arr[3] = 400;
    arr[4] = 500;
    std::print_string("  arr[0] = ");
    std::print_integer(arr[0]);
    std::print_string("\n");
    std::print_string("  arr[4] = ");
    std::print_integer(arr[4]);
    std::print_string("\n");
    
    // Test 5: Array with dynamic indexing
    std::print_string("\nTest 5: Dynamic Array Access\n");
    i64 arr_sum = 0;
    i64 idx = 0;
    loop {
        if idx >= 5 {
            break;
        }
        arr_sum = arr_sum + arr[idx];
        idx = idx + 1;
    }
    std::print_string("  Sum of array: ");
    std::print_integer(arr_sum);
    std::print_string("\n");
    
    // Test 6: Simple memory allocation
    std::print_string("\nTest 6: Memory Allocation\n");
    i64 mem1 = std::malloc(8);
    $mem1 = 42;
    std::print_string("  Value at allocated memory: ");
    std::print_integer($mem1);
    std::print_string("\n");
    
    // Test 7: Multiple allocations
    std::print_string("\nTest 7: Multiple Allocations\n");
    i64 mem2 = std::malloc(8);
    i64 mem3 = std::malloc(8);
    $mem2 = 100;
    $mem3 = 200;
    std::print_string("  mem2: ");
    std::print_integer($mem2);
    std::print_string(", mem3: ");
    std::print_integer($mem3);
    std::print_string("\n");
    
    // Test 8: Pointer arithmetic
    std::print_string("\nTest 8: Pointer Arithmetic\n");
    i64 base = std::malloc(24);
    $base = 10;
    $(base + 8) = 20;
    $(base + 16) = 30;
    std::print_string("  base[0]: ");
    std::print_integer($base);
    std::print_string(", base[1]: ");
    std::print_integer($(base + 8));
    std::print_string(", base[2]: ");
    std::print_integer($(base + 16));
    std::print_string("\n");
    
    // Test 9: Array storing pointers
    std::print_string("\nTest 9: Array of Pointers\n");
    array[3] i64 mem_arr;
    mem_arr[0] = std::malloc(8);
    mem_arr[1] = std::malloc(8);
    mem_arr[2] = std::malloc(8);
    $(mem_arr[0]) = 111;
    $(mem_arr[1]) = 222;
    $(mem_arr[2]) = 333;
    std::print_string("  mem_arr[0]: ");
    std::print_integer($(mem_arr[0]));
    std::print_string(", mem_arr[1]: ");
    std::print_integer($(mem_arr[1]));
    std::print_string(", mem_arr[2]: ");
    std::print_integer($(mem_arr[2]));
    std::print_string("\n");
    
    // Test 10: Loop with array and dereference
    std::print_string("\nTest 10: Loop with Array Access and Dereference\n");
    i64 i = 0;
    loop {
        if i >= 3 {
            break;
        }
        i64 addr = mem_arr[i];
        i64 val = $addr;
        std::print_string("  Element ");
        std::print_integer(i);
        std::print_string(": ");
        std::print_integer(val);
        std::print_string("\n");
        i = i + 1;
    }
    
    // Test 11: Linked structure
    std::print_string("\nTest 11: Linked Structure\n");
    i64 node1 = std::malloc(16);
    $node1 = 1000;
    $(node1 + 8) = 0;
    
    i64 node2 = std::malloc(16);
    $node2 = 2000;
    $(node2 + 8) = 0;
    
    i64 node3 = std::malloc(16);
    $node3 = 3000;
    $(node3 + 8) = 0;
    
    $(node1 + 8) = node2;
    $(node2 + 8) = node3;
    
    i64 current = node1;
    i64 node_count = 0;
    loop {
        if current == 0 {
            break;
        }
        std::print_string("  Node ");
        std::print_integer(node_count);
        std::print_string(" value: ");
        std::print_integer($current);
        std::print_string("\n");
        
        i64 next_mem = current + 8;
        current = $next_mem;
        node_count = node_count + 1;
    }
    
    // Test 12: Array storing linked list nodes
    std::print_string("\nTest 12: Array of Linked List Nodes\n");
    array[4] i64 nodes;
    
    nodes[0] = std::malloc(24);
    nodes[1] = std::malloc(24);
    nodes[2] = std::malloc(24);
    nodes[3] = std::malloc(24);
    
    $(nodes[0]) = 100;
    $(nodes[0] + 8) = nodes[1];
    $(nodes[0] + 16) = 1;
    
    $(nodes[1]) = 200;
    $(nodes[1] + 8) = nodes[2];
    $(nodes[1] + 16) = 2;
    
    $(nodes[2]) = 300;
    $(nodes[2] + 8) = nodes[3];
    $(nodes[2] + 16) = 3;
    
    $(nodes[3]) = 400;
    $(nodes[3] + 8) = 0;
    $(nodes[3] + 16) = 4;
    
    std::print_string("  Forward traversal:\n");
    current = nodes[0];
    loop {
        if current == 0 {
            break;
        }
        std::print_string("    value=");
        std::print_integer($current);
        std::print_string(", id=");
        std::print_integer($(current + 16));
        std::print_string("\n");
        
        current = $(current + 8);
    }
    
    // Test 13: Reverse array traversal with stored nodes
    std::print_string("\nTest 13: Reverse Traversal of Stored Nodes\n");
    i64 rev_i = 3;
    loop {
        i64 node_addr = nodes[rev_i];
        std::print_string("  nodes[");
        std::print_integer(rev_i);
        std::print_string("]: value=");
        std::print_integer($node_addr);
        std::print_string(", id=");
        std::print_integer($(node_addr + 16));
        std::print_string("\n");
        
        if rev_i == 0 {
            break;
        }
        rev_i = rev_i - 1;
    }
    
    std::print_string("\n=== All Tests Completed Successfully! ===\n");
    return 0;
}
