// Test case for print_string function
include "../std/stdio.occ"

fn main() i64 {
    // Test basic string printing
    std::print_string("Testing print_string function\n");
    
    // Test empty string
    std::print_string("");
    
    // Test special characters
    std::print_string("Test with spaces and symbols: !@#$%\n");
    
    return 0;
}
