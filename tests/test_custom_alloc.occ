include "../std/stdio.occ"

fn main() i64 {
    std::print_string("Testing custom alloc/del\n");
    
    i64 p = std::malloc(8);
    $p = 42;
    
    std::print_string("Stored value: ");
    std::print_integer($p);
    std::print_newline();
    
    std::free(p);
    
    std::print_string("Done\n");
    return 0;
}
