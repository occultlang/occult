include "../std/stdio.occ"

struct Point {
    i64 x;
    i64 y;
}

fn set_point(Point@ p, i64 a, i64 b) {
    $p.x = a;
    $p.y = b;
}

fn get_x(Point@ p) i64 {
    return $p.x;
}

fn get_y(Point@ p) i64 {
    return $p.y;
}

fn add_to_point(Point@ p, i64 dx, i64 dy) {
    $p.x = $p.x + dx;
    $p.y = $p.y + dy;
}

fn swap_coords(Point@ p) {
    i64 tmp = $p.x;
    $p.x = $p.y;
    $p.y = tmp;
}

fn main() {
    Point p;
    p.x = 10;
    p.y = 20;
    
    // Test basic set
    set_point(p, 100, 200);
    std::print_string("After set(100,200): (");
    std::print_integer(p.x);
    std::print_string(", ");
    std::print_integer(p.y);
    std::print_string(") expected (100, 200)\n");
    
    // Test reading through ref
    i64 x = get_x(p);
    i64 y = get_y(p);
    std::print_string("get_x = ");
    std::print_integer(x);
    std::print_string(" expected 100\n");
    std::print_string("get_y = ");
    std::print_integer(y);
    std::print_string(" expected 200\n");
    
    // Test read-modify-write
    add_to_point(p, 5, 10);
    std::print_string("After add(5,10): (");
    std::print_integer(p.x);
    std::print_string(", ");
    std::print_integer(p.y);
    std::print_string(") expected (105, 210)\n");
    
    // Test swap
    swap_coords(p);
    std::print_string("After swap: (");
    std::print_integer(p.x);
    std::print_string(", ");
    std::print_integer(p.y);
    std::print_string(") expected (210, 105)\n");
    
    return 0;
}
