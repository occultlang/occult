include "../lib/printf.occ"

module math {
    fn add(i64 a, i64 b) i64 {
        return a + b;
    }

    fn multiply(i64 a, i64 b) i64 {
        return a * b;
    }
}

fn main() i64 {
    i64 sum = math::add(3, 4);
    printf("3 + 4 = %d\n", sum);

    i64 product = math::multiply(5, 6);
    printf("5 * 6 = %d\n", product);

    return 0;
}
