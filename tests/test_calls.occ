// calling anywhere :cool:

include "../std/stdio.occ"

fn main() i64 {
  test_call();
  
  std::print_string("Hello, World!\n"); 
 
  return 0;
}

fn test_call() i64 {
  std::print_string("aaaaaaaa\n");
  
  test_call2();
  
  return 0;
}

fn test_call2() i64 {
  std::print_string("whaatt\n");
  
  return 0;
}
